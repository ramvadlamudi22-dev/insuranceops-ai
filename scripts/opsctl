#!/usr/bin/env python3
"""InsuranceOps AI operator CLI tool.

Subcommands:
    audit verify --workflow-run-id <UUID>
        Load audit events for the given workflow run and verify the hash chain.
        Exits 0 on success, 1 on failure.

    queue dlq count
        Print the number of entries in the dead letter queue.

    queue dlq list [--start N] [--count N]
        List DLQ entries with summary information.

    queue dlq inspect <index>
        Show the full payload of a DLQ entry at the given index.

    queue dlq requeue <index>
        Move a DLQ entry back to the ready queue for reprocessing.

    queue dlq drop <index>
        Remove a DLQ entry permanently without requeueing.
"""

from __future__ import annotations

import argparse
import asyncio
import json
import sys
import uuid


async def cmd_audit_verify(workflow_run_id: uuid.UUID) -> int:
    """Verify the audit chain for a workflow run.

    Returns:
        0 if the chain is valid, 1 otherwise.
    """
    from sqlalchemy.ext.asyncio import AsyncSession, create_async_engine
    from sqlalchemy.orm import sessionmaker

    from insuranceops.audit.verifier import verify_chain
    from insuranceops.config import Settings

    settings = Settings()
    engine = create_async_engine(settings.DATABASE_URL)
    async_session = sessionmaker(engine, class_=AsyncSession, expire_on_commit=False)

    try:
        async with async_session() as session:
            result = await verify_chain(session, workflow_run_id)

        if result.is_valid:
            print(f"PASS: {result.detail}")
            return 0
        else:
            print(f"FAIL: {result.detail}")
            print(f"  First mismatch at index: {result.first_mismatch_index}")
            return 1
    finally:
        await engine.dispose()


async def _get_redis():
    """Create a Redis client from settings."""
    from insuranceops.config import Settings
    from insuranceops.queue.redis_client import create_redis_pool

    settings = Settings()
    return await create_redis_pool(settings.REDIS_URL)


async def cmd_queue_dlq_count() -> int:
    """Print the DLQ entry count."""
    from insuranceops.queue.dlq import dlq_count

    client = await _get_redis()
    try:
        count = await dlq_count(client)
        print(f"DLQ entries: {count}")
        return 0
    finally:
        await client.aclose()


async def cmd_queue_dlq_list(start: int, count: int) -> int:
    """List DLQ entries with summary information."""
    from insuranceops.queue.dlq import dlq_count, list_dlq

    client = await _get_redis()
    try:
        total = await dlq_count(client)
        if total == 0:
            print("DLQ is empty.")
            return 0

        entries = await list_dlq(client, start=start, count=count)
        if not entries:
            print(f"No entries at offset {start} (total: {total}).")
            return 0

        print(f"DLQ entries (showing {start}-{start + len(entries) - 1} of {total}):")
        print("-" * 72)

        for i, entry in enumerate(entries):
            idx = start + i
            try:
                payload = json.loads(entry)
                workflow_run_id = payload.get("workflow_run_id", "?")
                step_name = payload.get("step_name", "?")
                attempt = payload.get("attempt_number", "?")
                print(
                    f"  [{idx}] workflow_run_id={workflow_run_id} "
                    f"step={step_name} attempt={attempt}"
                )
            except (json.JSONDecodeError, ValueError):
                print(f"  [{idx}] <malformed payload: {len(entry)} bytes>")

        print("-" * 72)
        print(f"Total: {total}")
        return 0
    finally:
        await client.aclose()


async def cmd_queue_dlq_inspect(index: int) -> int:
    """Show full payload of a DLQ entry."""
    from insuranceops.queue.dlq import get_dlq_entry

    client = await _get_redis()
    try:
        entry = await get_dlq_entry(client, index)
        if entry is None:
            print(f"ERROR: No DLQ entry at index {index}.", file=sys.stderr)
            return 1

        try:
            payload = json.loads(entry)
            print(json.dumps(payload, indent=2, default=str))
        except (json.JSONDecodeError, ValueError):
            print(f"<raw bytes: {entry!r}>")

        return 0
    finally:
        await client.aclose()


async def cmd_queue_dlq_requeue(index: int) -> int:
    """Move a DLQ entry back to the ready queue."""
    from insuranceops.queue.dlq import get_dlq_entry, requeue_from_dlq

    client = await _get_redis()
    try:
        entry = await get_dlq_entry(client, index)
        if entry is None:
            print(f"ERROR: No DLQ entry at index {index}.", file=sys.stderr)
            return 1

        # Show what we're about to requeue
        try:
            payload = json.loads(entry)
            step_name = payload.get("step_name", "?")
            workflow_run_id = payload.get("workflow_run_id", "?")
            print(f"Requeueing DLQ[{index}]: workflow_run_id={workflow_run_id} step={step_name}")
        except (json.JSONDecodeError, ValueError):
            print(f"Requeueing DLQ[{index}]: <malformed payload>")

        success = await requeue_from_dlq(client, entry)
        if success:
            print("OK: Entry moved from DLQ to ready queue.")
            return 0
        else:
            print(
                "WARNING: Entry was not found in DLQ (may have been removed concurrently).",
                file=sys.stderr,
            )
            return 1
    finally:
        await client.aclose()


async def cmd_queue_dlq_drop(index: int) -> int:
    """Remove a DLQ entry permanently."""
    from insuranceops.queue.dlq import drop_from_dlq, get_dlq_entry

    client = await _get_redis()
    try:
        entry = await get_dlq_entry(client, index)
        if entry is None:
            print(f"ERROR: No DLQ entry at index {index}.", file=sys.stderr)
            return 1

        # Show what we're about to drop
        try:
            payload = json.loads(entry)
            step_name = payload.get("step_name", "?")
            workflow_run_id = payload.get("workflow_run_id", "?")
            print(f"Dropping DLQ[{index}]: workflow_run_id={workflow_run_id} step={step_name}")
        except (json.JSONDecodeError, ValueError):
            print(f"Dropping DLQ[{index}]: <malformed payload>")

        success = await drop_from_dlq(client, entry)
        if success:
            print("OK: Entry permanently removed from DLQ.")
            return 0
        else:
            print(
                "WARNING: Entry was not found in DLQ (may have been removed concurrently).",
                file=sys.stderr,
            )
            return 1
    finally:
        await client.aclose()


def main() -> None:
    """Parse arguments and dispatch to subcommands."""
    parser = argparse.ArgumentParser(
        prog="opsctl",
        description="InsuranceOps AI operator CLI tool",
    )
    subparsers = parser.add_subparsers(dest="command", help="Available commands")

    # ── audit ─────────────────────────────────────────────────────────────────
    audit_parser = subparsers.add_parser("audit", help="Audit chain operations")
    audit_subparsers = audit_parser.add_subparsers(dest="audit_command", help="Audit subcommands")

    # audit verify
    verify_parser = audit_subparsers.add_parser("verify", help="Verify audit chain integrity")
    verify_parser.add_argument(
        "--workflow-run-id",
        type=uuid.UUID,
        required=True,
        help="UUID of the workflow run to verify",
    )

    # ── queue ─────────────────────────────────────────────────────────────────
    queue_parser = subparsers.add_parser("queue", help="Queue operations")
    queue_subparsers = queue_parser.add_subparsers(dest="queue_command", help="Queue subcommands")

    # queue dlq
    dlq_parser = queue_subparsers.add_parser("dlq", help="Dead letter queue operations")
    dlq_subparsers = dlq_parser.add_subparsers(dest="dlq_command", help="DLQ subcommands")

    # queue dlq count
    dlq_subparsers.add_parser("count", help="Show DLQ entry count")

    # queue dlq list
    dlq_list_parser = dlq_subparsers.add_parser("list", help="List DLQ entries")
    dlq_list_parser.add_argument("--start", type=int, default=0, help="Start index (default: 0)")
    dlq_list_parser.add_argument(
        "--count", type=int, default=20, help="Number of entries to show (default: 20)"
    )

    # queue dlq inspect
    dlq_inspect_parser = dlq_subparsers.add_parser(
        "inspect", help="Show full payload of a DLQ entry"
    )
    dlq_inspect_parser.add_argument("index", type=int, help="0-based DLQ entry index")

    # queue dlq requeue
    dlq_requeue_parser = dlq_subparsers.add_parser(
        "requeue", help="Move a DLQ entry back to the ready queue"
    )
    dlq_requeue_parser.add_argument("index", type=int, help="0-based DLQ entry index")

    # queue dlq drop
    dlq_drop_parser = dlq_subparsers.add_parser("drop", help="Remove a DLQ entry permanently")
    dlq_drop_parser.add_argument("index", type=int, help="0-based DLQ entry index")

    # ── dispatch ──────────────────────────────────────────────────────────────
    args = parser.parse_args()

    if args.command == "audit" and getattr(args, "audit_command", None) == "verify":
        exit_code = asyncio.run(cmd_audit_verify(args.workflow_run_id))
        sys.exit(exit_code)
    elif args.command == "queue" and getattr(args, "queue_command", None) == "dlq":
        dlq_cmd = getattr(args, "dlq_command", None)
        if dlq_cmd == "count":
            sys.exit(asyncio.run(cmd_queue_dlq_count()))
        elif dlq_cmd == "list":
            sys.exit(asyncio.run(cmd_queue_dlq_list(args.start, args.count)))
        elif dlq_cmd == "inspect":
            sys.exit(asyncio.run(cmd_queue_dlq_inspect(args.index)))
        elif dlq_cmd == "requeue":
            sys.exit(asyncio.run(cmd_queue_dlq_requeue(args.index)))
        elif dlq_cmd == "drop":
            sys.exit(asyncio.run(cmd_queue_dlq_drop(args.index)))
        else:
            dlq_parser.print_help()
            sys.exit(1)
    else:
        parser.print_help()
        sys.exit(1)


if __name__ == "__main__":
    main()
