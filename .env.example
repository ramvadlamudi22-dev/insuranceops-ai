# Database connection string (async driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/insuranceops

# Redis connection string
REDIS_URL=redis://localhost:6379/0

# Pepper for API key hashing: sha256(pepper || token)
# MUST be changed in production - use a cryptographically random string
API_KEY_HASH_PEPPER=dev-pepper-not-for-production

# Maximum request body size in bytes (default: 20MB)
MAX_REQUEST_BYTES=20971520

# Worker visibility timeout in seconds before task is considered stuck
WORKER_VISIBILITY_TIMEOUT_S=60

# Number of concurrent tasks per worker process
WORKER_CONCURRENCY=1

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Environment name (local, test, staging, production)
ENV=local

# Whether to assume TLS is terminated upstream (set true behind a reverse proxy)
ASSUME_TLS_TERMINATOR=false

# Filesystem path for document payload storage
PAYLOAD_STORAGE_PATH=/data/payloads
