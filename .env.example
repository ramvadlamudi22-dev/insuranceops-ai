# InsuranceOps AI — Environment Configuration
#
# Copy this file to .env and fill in real values for your deployment.
# This file contains variable NAMES only — never commit real secrets.
#
# Required variables will cause a startup failure if missing or empty.
# Optional variables have sensible defaults shown in comments.

# ─────────────────────────────────────────────────────────────────────────────
# Core Infrastructure
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string (required)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/insuranceops

# Redis connection string (required)
REDIS_URL=redis://localhost:6379/0

# ─────────────────────────────────────────────────────────────────────────────
# Security
# ─────────────────────────────────────────────────────────────────────────────

# Pepper for API key hashing: sha256(pepper || token) (required)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY_HASH_PEPPER=CHANGE_ME_generate_a_32_byte_secret

# ─────────────────────────────────────────────────────────────────────────────
# Application Settings
# ─────────────────────────────────────────────────────────────────────────────

# Environment identifier (required: local, ci, staging, production)
ENV=local

# Structured log level (optional, default: INFO)
# LOG_LEVEL=INFO

# Maximum request body size in bytes (optional, default: 20 MiB)
# MAX_REQUEST_BYTES=20971520

# Assume TLS is terminated upstream (optional, default: false)
# ASSUME_TLS_TERMINATOR=false

# Document payload storage path (optional, default: /data/payloads)
# PAYLOAD_STORAGE_PATH=/data/payloads

# ─────────────────────────────────────────────────────────────────────────────
# Worker Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Visibility timeout for inflight tasks in seconds (optional, default: 60)
# WORKER_VISIBILITY_TIMEOUT_S=60

# Number of concurrent task handlers per worker (optional, default: 1)
# WORKER_CONCURRENCY=1

# ─────────────────────────────────────────────────────────────────────────────
# Scheduled Audit Verifier
# ─────────────────────────────────────────────────────────────────────────────

# Interval between verification cycles in seconds (optional, default: 3600)
# AUDIT_VERIFY_INTERVAL_S=3600

# Number of terminal workflow runs to verify per cycle (optional, default: 10)
# AUDIT_VERIFY_SAMPLE_SIZE=10

# ─────────────────────────────────────────────────────────────────────────────
# Rate Limiting (per-API-key fixed-window)
# ─────────────────────────────────────────────────────────────────────────────

# Enable/disable rate limiting (optional, default: true)
# RATE_LIMIT_ENABLED=true

# Fixed window duration in seconds (optional, default: 60)
# RATE_LIMIT_WINDOW_SECONDS=60

# Max requests per window by role (optional)
# RATE_LIMIT_OPERATOR_MAX=1200
# RATE_LIMIT_SUPERVISOR_MAX=1200
# RATE_LIMIT_VIEWER_MAX=600

# ─────────────────────────────────────────────────────────────────────────────
# Tracing (optional — no-op when unset)
# ─────────────────────────────────────────────────────────────────────────────

# OpenTelemetry OTLP endpoint (unset = tracing disabled)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
